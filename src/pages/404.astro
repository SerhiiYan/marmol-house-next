---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';

// Добавляем базовый description, чтобы Layout не сломался
const pageDescription = "Страница не найдена или была удалена.";
---

<Layout title="Страница не найдена | 404" description={pageDescription}>
    
    <meta name="robots" content="noindex, nofollow" slot="head" />

    <main class="relative min-h-screen bg-marmol-navy flex items-center justify-center overflow-hidden">
        
        <div class="absolute inset-0 opacity-10 pointer-events-none" 
             style="background-image: 
                linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px);
                background-size: 40px 40px;">
        </div>

        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-marmol-gold/20 rounded-full blur-[100px] pointer-events-none"></div>

        <div class="relative z-10 text-center px-4">
            
            <h1 class="font-sans font-bold text-[120px] md:text-[200px] leading-none text-transparent tracking-widest select-none animate-pulse-slow">
                404
            </h1>
            
            <h2 class="text-2xl md:text-3xl text-white font-bold mb-4 mt-8">
                Страница не найдена
            </h2>
            
            <p class="text-gray-400 text-base md:text-lg max-w-md mx-auto mb-10 font-light">
                Похоже, эта страница еще на этапе проектирования или была перенесена.
            </p>

            <div class="flex flex-col md:flex-row items-center justify-center gap-4">
                <a href="/" class="w-full md:w-auto px-8 py-4 bg-marmol-gold text-marmol-navy font-bold uppercase tracking-widest text-xs rounded hover:bg-white transition-all shadow-xl">
                    На главную
                </a>
                <a href="/projects" class="w-full md:w-auto px-8 py-4 border border-white/20 text-white font-bold uppercase tracking-widest text-xs rounded hover:border-marmol-gold hover:text-marmol-gold transition-all">
                    Смотреть проекты
                </a>
            </div>

        </div>
    </main>

</Layout>

<style>
    h1 {
        /* Добавили фоллбэк: если сборщик не найдет переменную, он возьмет HEX, и билд не упадет */
        -webkit-text-stroke: 2px theme('colors.marmol-gold', #D4AF37);
        
        /* Для тени то же самое */
        text-shadow: 0 0 20px theme('colors.marmol-gold / 30%', rgba(212, 175, 55, 0.3));
    }
    
    @keyframes pulseSlow {
        0%, 100% { opacity: 0.8; transform: scale(1); }
        50% { opacity: 1; transform: scale(1.02); }
    }
    
    .animate-pulse-slow {
        animation: pulseSlow 4s ease-in-out infinite;
    }
</style>