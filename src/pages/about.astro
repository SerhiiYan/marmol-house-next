---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
// Header и Footer не импортируем, они должны быть внутри Layout

// SEO Мета-данные
const pageTitle = "О компании Marmol House | Строительство домов в Гродно";
const pageDescription = "Marmol House — строительная компания полного цикла. Более 10 лет строим надежные дома из блоков и по каркасной технологии в Гродно и области. Проектирование, честная смета, гарантия.";

// Расширенная Schema.org для локального бизнеса
const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "mainEntity": {
    "@type": "ConstructionBusiness",
    "name": "Marmol House",
    "url": "https://marmolhouse.by",
    "logo": "https://marmolhouse.by/logo-bg.png", 
    "telephone": "+375(29)184-54-81",
    "taxID": "591536542",
    "foundingDate": "2025",
    "description": pageDescription,
    "areaServed": ["Гродно", "Минская область", "Гродненская область"]
  }
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <main class="bg-white">
    
    <section class="relative min-h-screen flex items-center pt-20 bg-white overflow-hidden">

        <div class="hidden lg:block absolute top-0 right-0 w-[45%] h-full z-0">
            <img
                src="/hero-mobile.webp"
                alt="Архитектура и строительство домов Marmol House"
                loading="eager"
                fetchpriority="high"
                class="w-full h-full object-cover object-center opacity-90 grayscale-[20%]"
            />
            
            <div class="absolute inset-0 bg-gradient-to-r from-white via-white/60 to-transparent"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-white via-transparent to-white opacity-90"></div>
        </div>
    
        <div class="max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 relative z-10 h-full flex flex-col justify-center min-h-screen pb-32 md:pb-0">
            <div class="max-w-4xl lg:w-[65%]">
    
                <h1 class="text-marmol-gold font-bold uppercase tracking-[0.2em] text-xs md:text-sm mb-6 animate-fade-in">
                    Строительство домов в Гродно от Marmol House
                </h1>
            
                <p class="text-4xl md:text-6xl xl:text-7xl font-sans font-bold text-marmol-navy leading-[1.1] mb-10 animate-fade-in-up">
                    Мы не запускаем <br class="hidden md:block" /> 
                    громкую рекламу — <br/>
                    <span class="text-gray-400 font-light italic">нас советуют друзьям.</span>
                </p>
            
                <div class="flex flex-col md:flex-row items-start gap-6 md:gap-10 animate-fade-in-up" style="animation-delay: 0.2s;">
                    <div class="h-1 w-16 md:w-24 bg-marmol-gold mt-3 shrink-0"></div>
                    
                    <div class="text-base md:text-lg text-gray-600 font-light leading-relaxed max-w-lg">
                        Строительство — это баланс между инженерной точностью и архитектурной эстетикой. 
                        Мы объединяем надежность каменных стен с красотой премиальных фасадов.
                    </div>
                </div>
            </div>
        </div>
    
    </section>

    <section class="py-24 bg-marmol-navy text-white relative overflow-hidden">

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                
                <div class="lg:col-span-5">
                    <h2 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
                        Более <span class="text-marmol-gold">10 лет</span> <br/> 
                        создаем архитектурный облик Гродно
                    </h2>
                    <p class="text-marmol-gold uppercase tracking-widest text-sm font-bold mb-8">
                        Marmol House — от идеи до ключа
                    </p>
                    <div class="h-0.5 w-full bg-gradient-to-r from-marmol-gold to-transparent opacity-30"></div>
                </div>

                <div class="lg:col-span-7 space-y-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        <div>
                            <h3 class="text-marmol-gold font-bold mb-3 uppercase text-xs tracking-wider">Наш масштаб</h3>
                            <p class="text-gray-300 text-sm leading-relaxed">
                                Marmol House — компания для комплексного возведения жилых домов. Более 10 лет мы совершенствуем технологию строительства полного цикла: от 
                                <a href="/services/design" class="text-white border-b border-white/30 hover:border-marmol-gold hover:text-marmol-gold transition-colors">проектирования</a> 
                                фундамента до ювелирной точности в финишной отделке 
                                <a href="/services/facades" class="text-white border-b border-white/30 hover:border-marmol-gold hover:text-marmol-gold transition-colors">клинкером</a>.
                            </p>
                        </div>
                        <div>
                            <h3 class="text-marmol-gold font-bold mb-3 uppercase text-xs tracking-wider">Локальная экспертиза</h3>
                            <p class="text-gray-300 text-sm leading-relaxed">
                                Мы специализируемся на строительстве в Гродно и области, досконально зная требования региональных норм и особенности местных площадок. Это позволяет нам гарантировать безупречное качество 
                                <a href="/services/gas-silicate-houses" class="text-white border-b border-white/30 hover:border-marmol-gold hover:text-marmol-gold transition-colors">каменных домов</a>, 
                                которые сохраняют свою геометрию и теплотехнические свойства в любом районе области.
                            </p>
                        </div>
                    </div>

                    <blockquote class="bg-white/5 border-l-4 border-marmol-gold p-8 rounded-r-lg italic text-lg text-gray-200 font-light">
                        "Дом считается построенным не в день сдачи ключей, а через десятилетия, когда он всё так же надежен и эстетичен. Мы строим для тех, кто любит качество."
                    </blockquote>
                </div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-20 border-t border-white/10 pt-12">
                <div class="text-center">
                    <div class="text-4xl font-bold text-white mb-1">20+</div>
                    <div class="text-[10px] uppercase tracking-[0.2em] text-marmol-gold">Построенных домов</div>
                </div>
                <div class="text-center border-l border-white/10">
                    <div class="text-4xl font-bold text-white mb-1">100%</div>
                    <div class="text-[10px] uppercase tracking-[0.2em] text-marmol-gold">Соблюдение сроков</div>
                </div>
                <div class="text-center border-l border-white/10">
                    <div class="text-4xl font-bold text-white mb-1">0</div>
                    <div class="text-[10px] uppercase tracking-[0.2em] text-marmol-gold">Скрытых платежей</div>
                </div>
                <div class="text-center border-l border-white/10">
                    <div class="text-4xl font-bold text-white mb-1">8/10</div>
                    <div class="text-[10px] uppercase tracking-[0.2em] text-marmol-gold">Приходят по совету</div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-sans font-bold text-marmol-navy mb-4">Принципы Marmol House</h2>
                <div class="w-20 h-1 bg-marmol-gold mx-auto"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 border-t border-gray-100">
                <div class="p-10 md:p-12 border-b md:border-b-0 md:border-r border-gray-100 group hover:bg-gray-50 transition-colors duration-500">
                    <div class="mb-8 text-marmol-gold">
                        <svg aria-hidden="true" class="w-10 h-10 transition-transform duration-500 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-marmol-navy mb-4 uppercase tracking-wider text-sm">География качества</h3>
                    <p class="text-gray-500 text-sm leading-relaxed font-light">
                        Начав свой путь в Гродно, мы сформировали команду экспертов для работы по всей области. Реализуем как <a href="/services/frame-houses" class="text-marmol-navy border-b border-gray-200 hover:text-marmol-gold hover:border-marmol-gold transition-colors">каркасные</a>, так и блочные проекты.
                    </p>
                </div>

                <div class="p-10 md:p-12 border-b md:border-b-0 md:border-r border-gray-100 group hover:bg-gray-50 transition-colors duration-500">
                    <div class="mb-8 text-marmol-gold">
                        <svg aria-hidden="true" class="w-10 h-10 transition-transform duration-500 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-marmol-navy mb-4 uppercase tracking-wider text-sm">Честная смета</h3>
                    <p class="text-gray-500 text-sm leading-relaxed font-light">
                        Фиксируем цену в договоре. Никаких «непредвиденных расходов» в процессе. Вы можете <a href="/projects" class="text-marmol-navy border-b border-gray-200 hover:text-marmol-gold hover:border-marmol-gold transition-colors">выбрать проект</a> в каталоге и узнать его точную стоимость.
                    </p>
                </div>

                <div class="p-10 md:p-12 border-b md:border-b-0 border-gray-100 group hover:bg-gray-50 transition-colors duration-500">
                    <div class="mb-8 text-marmol-gold">
                        <svg aria-hidden="true" class="w-10 h-10 transition-transform duration-500 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-marmol-navy mb-4 uppercase tracking-wider text-sm">Авторский надзор</h3>
                    <p class="text-gray-500 text-sm leading-relaxed font-light">
                        Мы не просто строим, мы следим за тем, чтобы эстетика проекта была реализована на 100%, от шва кирпича до отлива.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="relative py-24 flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 w-full h-full">
            <img 
                loading="lazy"
                src="/brick-offer/ceramic-facade.webp" 
                alt="Построить дом в Гродно" 
                class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-marmol-navy/85 mix-blend-multiply"></div>
        </div>

        <div class="relative z-10 max-w-3xl mx-auto px-4 text-center">
            <div class="w-16 h-1 bg-marmol-gold mx-auto mb-8"></div>
            
            <h2 class="text-3xl md:text-4xl font-sans font-bold text-white mb-6 leading-tight">
                Готовы обсудить строительство <br /> вашего дома?
            </h2>
            <p class="text-gray-300 mb-10 text-base md:text-lg font-light max-w-xl mx-auto">
                Оставьте заявку на консультацию. Мы ответим на технические вопросы, поможем подобрать проект под ваш бюджет и рассчитаем честную смету.
            </p>
            
            <address class="not-italic flex items-center justify-center gap-2 text-marmol-gold font-bold text-sm uppercase tracking-wider mb-8">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                </svg>
                <span>г. Гродно, ул. Лелевеля, 12, каб. 6</span>
            </address>
            
            <button 
                id="about-consult-btn" 
                class="inline-flex items-center bg-white text-marmol-navy hover:bg-marmol-gold hover:text-white transition-all duration-300 font-bold uppercase tracking-widest text-xs py-5 px-10 shadow-xl rounded-sm transform hover:-translate-y-1 cursor-pointer"
            >
                Записаться на консультацию
            </button>
        </div>
    </section>

  </main>

</Layout>

<script>
    import { isModalOpen, formComment } from '../store/modalStore';

    const setupAboutBtn = () => {
        const btn = document.getElementById('about-consult-btn');
        if (btn) {
            // Клонируем кнопку, чтобы избежать дублирования событий при переходах
            const newBtn = btn.cloneNode(true);
            if (btn.parentNode) btn.parentNode.replaceChild(newBtn, btn);

            newBtn.addEventListener('click', () => {
                formComment.set(`Здравствуйте! Хочу записаться на консультацию.`);
                isModalOpen.set(true);
            });
        }
    };

    // Поддержка Astro View Transitions
    document.addEventListener('astro:page-load', setupAboutBtn);
    setupAboutBtn();
</script>