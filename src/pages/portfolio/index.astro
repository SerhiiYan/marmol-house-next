---
// src/pages/portfolio/index.astro
import Layout from '../../layouts/Layout.astro';
import PortfolioList from '../../components/portfolio/PortfolioList.jsx';
import { getCollection } from 'astro:content';

// Получаем и сортируем проекты (от новых к старым)
const allProjects = await getCollection('portfolio');
const sortedProjects = allProjects.sort((a, b) => b.data.specs.year - a.data.specs.year);

// SEO Мета-данные
const pageTitle = "Наши проекты | Портфолио строительства Marmol House";
const pageDescription = "Галерея реализованных проектов Marmol House. Фотографии построенных каркасных и каменных домов в Гродно и области. Качество, которое можно увидеть.";

// Микроразметка Schema.org
const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Портфолио Marmol House",
  "description": pageDescription,
  "provider": {
    "@type": "ConstructionBusiness",
    "name": "Marmol House"
  }
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <main class="bg-gray-50 min-h-screen pt-28 pb-24 relative overflow-hidden">
    
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-marmol-navy/5 rounded-full blur-3xl pointer-events-none -translate-y-1/2 translate-x-1/3"></div>

    <section class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto relative z-10">
        
        <div class="mb-12 max-w-3xl animate-fade-in">
            <div class="inline-block bg-marmol-gold text-marmol-navy text-[10px] font-bold uppercase tracking-widest px-3 py-1 mb-4 rounded-sm shadow-sm">
                Галерея работ
            </div>
            
            <h1 class="text-4xl md:text-5xl font-sans font-bold text-marmol-navy mb-6">
                Реализованные проекты домов
            </h1>
            
            <p class="text-gray-500 text-lg leading-relaxed font-light">
                Мы не просто рисуем красивые рендеры — мы строим надежные дома для комфортной жизни. 
                Посмотрите фотографии наших реальных объектов в <strong class="font-medium text-marmol-navy">Гродно и области</strong>: 
                от закладки фундамента до готового клинкерного фасада.
            </p>
        </div>

        <PortfolioList items={sortedProjects} client:load />

    </section>
  </main>
</Layout>