---
// src/pages/portfolio/index.astro
import Layout from '../../layouts/Layout.astro';
import PortfolioList from '../../components/portfolio/PortfolioList.jsx';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('portfolio');
const sortedProjects = allProjects.sort((a, b) => b.data.specs.year - a.data.specs.year);

const pageTitle = "Портфолио построенных домов в Гродно | Marmol House";
const pageDescription = "Галерея реализованных проектов Marmol House. Посмотрите наши готовые каркасные и блочные дома в Гродно и области.";

// Улучшенная микроразметка: теперь Google видит все проекты списком
const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Реализованные проекты Marmol House",
  "description": pageDescription,
  "numberOfItems": sortedProjects.length,
  "itemListElement": sortedProjects.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "url": `https://marmolhouse.by/portfolio/${item.slug}`,
    "name": item.data.title
  }))
};
---

{/* Передаем schema прямо в компонент Layout, как мы его и настроили! */}
<Layout title={pageTitle} description={pageDescription} schema={schema}>

  <main class="bg-gray-50 min-h-screen pt-28 pb-24 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-marmol-navy/5 rounded-full blur-3xl pointer-events-none -translate-y-1/2 translate-x-1/3"></div>

    <section class="px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto relative z-10">
        
        <div class="mb-10 max-w-3xl animate-fade-in text-center md:text-left mx-auto md:mx-0">
            <h1 class="text-4xl md:text-5xl font-sans font-bold text-marmol-navy mb-6">
                <span class="block text-lg text-marmol-gold font-normal mb-2 tracking-normal">Наши работы</span>
                Реализованные проекты
            </h1>
            <p class="text-gray-500 text-lg leading-relaxed font-light">
                Взгляните на готовые фасады наших домов, а также на ход строительства в данный момент, чтобы увидеть качество скрытых работ.
            </p>
        </div>

        {/* === ПЕРЕКЛЮЧАТЕЛЬ === */}
        <div class="flex justify-center md:justify-start mb-12 animate-fade-in">
            <div class="bg-white p-1.5 rounded-full inline-flex shadow-sm border border-gray-100 w-full sm:w-auto relative">
                {/* Активная ссылка (Портфолио) */}
                <a 
                    href="/portfolio" 
                    class="flex-1 sm:flex-none px-8 py-3 text-xs font-bold uppercase tracking-widest rounded-full transition-all duration-300 bg-marmol-navy text-white shadow-md text-center block"
                >
                    Готовые проекты
                </a>
                {/* Неактивная ссылка (Дневник) */}
                <a 
                    href="/diary" 
                    class="flex-1 sm:flex-none px-8 py-3 text-xs font-bold uppercase tracking-widest rounded-full transition-all duration-300 text-gray-500 hover:text-marmol-navy text-center block"
                >
                    Ход строительства
                </a>
            </div>
        </div>

        {/* Только готовые проекты */}
        <div class="animate-fade-in">
            <PortfolioList items={sortedProjects} client:load />
        </div>

    </section>
  </main>
</Layout>