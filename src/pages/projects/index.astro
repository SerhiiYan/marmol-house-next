---
// src/pages/projects/index.astro
import Layout from '../../layouts/Layout.astro';
import ProjectCatalog from '../../components/catalog/ProjectCatalog.jsx'; 
import { getCollection } from 'astro:content';

// 1. ПОЛУЧАЕМ ПРОЕКТЫ
const allProjects = await getCollection('projects');

// SEO Schema (Микроразметка списка - Отлично!)
const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Каталог проектов домов Marmol House",
  "url": "https://marmolhouse.by/projects",
  "numberOfItems": allProjects.length,
  "itemListElement": allProjects.map((p, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "url": `https://marmolhouse.by/projects/${p.id}`,
    "name": p.data.title
  }))
};

// Мета-теги
const pageTitle = "Каталог проектов домов и коттеджей под ключ | Marmol House";
const pageDescription = "Выбирайте готовые проекты каркасных и блочных домов с продуманными планировками. Строительство под ключ в Гродно, Минске и по всей Беларуси. Фиксированная цена.";
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <main class="bg-gray-50 min-h-screen pt-28 pb-24 relative overflow-hidden">
    
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-marmol-gold/5 rounded-full blur-3xl pointer-events-none -translate-y-1/2 translate-x-1/3"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <div class="mb-12 max-w-3xl">
        <div class="inline-block bg-marmol-gold text-marmol-navy text-[10px] font-bold uppercase tracking-widest px-3 py-1 mb-4 rounded-sm shadow-sm">
            Выберите свой дом
        </div>
        
        <h1 class="text-4xl md:text-5xl font-sans font-bold text-marmol-navy mb-6">
            Каталог проектов домов
        </h1>
        
        <p class="text-gray-500 text-lg leading-relaxed font-light">
            Продуманные до миллиметра планировки для комфортной жизни. 
            Мы адаптируем любой проект под ваши пожелания и построим его из 
            <strong class="font-medium text-marmol-navy">блоков или по каркасной технологии</strong>.
        </p>
      </div>

      <ProjectCatalog allProjects={allProjects} client:load />

    </div>
  </main>
</Layout>