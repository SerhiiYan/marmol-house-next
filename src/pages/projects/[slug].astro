---
// src/pages/projects/[slug].astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { globalPricing } from '../../data/pricingConfig';
import ProjectPricing from '../../components/project/ProjectPricing.jsx';
import ConsultationModal from '../../components/ui/ConsultationModal.jsx';

// ИМПОРТ НОВЫХ КОМПОНЕНТОВ
import ProjectGallery from '../../components/project/ProjectGallery.jsx';
import PlanViewer from '../../components/project/PlanViewer.jsx';

// 1. ГЕНЕРАЦИЯ ПУТЕЙ
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const data = project.data;

// --- ЛОГИКА ЦЕНЫ ---
// @ts-ignore
const categoryKey = data.priceCategory || 'economy';
const basePrice = globalPricing.packages[categoryKey]?.basePricePerMeter || 0;

// Вот здесь магия: если в JSON есть fixPrice, берем его. Иначе считаем площадь * тариф.
const totalPrice = data.fixPrice || (data.area * basePrice);

const formatPrice = (p) => p.toLocaleString('ru-RU');

// --- ЧИСТОЕ SEO ---
// 1. Формируем Title
const cleanTitle = data.title.replace('Проект ', '');
const pageTitle = `Проект дома ${cleanTitle} (${data.area} м²) | Marmol House`;

// 2. Умный Description
// Проверяем массив технологий, чтобы составить грамотное описание
const techText = data.availableTech.includes('frame') ? 'каркасной технологии' : 'газосиликатных блоков';
const generatedDesc = `Готовый проект дома ${data.title}. Площадь: ${data.area} м². Строительство по ${techText} под ключ. Изучите планировку и рассчитайте стоимость.`;

// 2. Умная обрезка текста для SEO (не рубит слова пополам)
let finalSeoDescription = generatedDesc;

if (data.description) {
    if (data.description.length <= 155) {
        finalSeoDescription = data.description;
    } else {
        // Используем современный метод .slice() вместо устаревшего .substr()
        const truncated = data.description.slice(0, 155);
        const lastSpaceIndex = truncated.lastIndexOf(" ");
        
        // Если пробел не найден (вся строка - одно слово), просто режем как есть
        if (lastSpaceIndex === -1) {
             finalSeoDescription = truncated + "...";
        } else {
             finalSeoDescription = truncated.slice(0, lastSpaceIndex) + "...";
        }
    }
}

const pageDescription = finalSeoDescription;

// 3. Микроразметка Product
const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": `Проект дома ${data.title}`,
  "image": data.mainImage,
  "description": pageDescription,
  "offers": {
    "@type": "Offer",
    "price": totalPrice,
    "priceCurrency": globalPricing.currency,
    "availability": "https://schema.org/InStock",
    "url": `https://marmolhouse.by/projects/${project.id}`
  }
};
---

<Layout title={pageTitle} description={pageDescription} schema={schema} image={data.mainImage}>
  
  <main class="bg-gray-50 pb-24">
    
    <!-- 1. HERO IMAGE -->
    <div class="relative h-[60vh] min-h-[400px] w-full overflow-hidden">
        <img 
            src={data.mainImage} 
            alt={`Проект дома ${data.title} - фасад`}
            loading="eager" 
            class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-black/30"></div>
        <div class="absolute bottom-0 left-0 w-full p-6 pb-24 md:p-12 md:pb-12">
            <div class="max-w-7xl mx-auto">
                <div class="inline-block bg-marmol-gold text-marmol-navy text-xs font-bold uppercase tracking-widest px-3 py-1 mb-4 rounded-sm">
                    {data.style || data.category}
                </div>
                <h1 class="text-4xl md:text-6xl font-bold text-white mb-2">{data.title}</h1>
                <p class="text-gray-300 text-lg flex items-center gap-4">
                    {data.dims && (
                        <>
                            <span>{data.dims}</span>
                            <span class="w-1 h-1 bg-marmol-gold rounded-full"></span>
                        </>
                    )}
                    <span>{data.area} м²</span>
                </p>
            </div>
        </div>
    </div>

    <!-- 2. КОНТЕНТ -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-10 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- ЛЕВАЯ КОЛОНКА -->
            <div class="lg:col-span-2 space-y-12">
                
                <!-- Характеристики (Ты сделал правильно через dl/dt - это семантично!) -->
                <section class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
                    
                    <dl class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8 border-b border-gray-100 pb-8">
                        <div class="text-center md:text-left">
                            <dt class="text-gray-400 text-xs uppercase mb-1">Площадь</dt>
                            <dd class="text-2xl font-bold text-marmol-navy m-0">{data.area} <span class="text-sm">м²</span></dd>
                        </div>
                        <div class="text-center md:text-left">
                            <dt class="text-gray-400 text-xs uppercase mb-1">Комнат</dt>
                            <dd class="text-2xl font-bold text-marmol-navy m-0">{data.specs?.rooms || '-'}</dd>
                        </div>
                        <div class="text-center md:text-left">
                            <dt class="text-gray-400 text-xs uppercase mb-1">Санузлов</dt>
                            <dd class="text-2xl font-bold text-marmol-navy m-0">{data.specs?.bathrooms || '-'}</dd>
                        </div>
                        <div class="text-center md:text-left">
                            <dt class="text-gray-400 text-xs uppercase mb-1">Технология</dt>
                            <dd class="text-sm font-bold text-marmol-navy leading-tight mt-1 m-0">
                                {data.availableTech.map(t => t === 'frame' ? 'Каркас ' : 'Блок ').join('/ ')}
                            </dd>
                        </div>
                    </dl>

                    <h2 class="text-2xl font-bold text-marmol-navy mb-4">О проекте</h2>
                    <div class="prose prose-slate text-gray-600 leading-relaxed">
                        <p>{data.fullDescription || data.description}</p>
                    </div>

                    {data.features && (
                        <div class="mt-8">
                            <h3 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-4">Особенности</h3>
                            <div class="flex flex-wrap gap-3">
                                {data.features.map(f => (
                                    <span class="px-4 py-2 bg-gray-50 text-marmol-navy text-sm font-medium rounded-lg border border-gray-200 flex items-center">
                                        <svg aria-hidden="true" class="w-4 h-4 text-marmol-gold mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                                        {f}
                                    </span>
                                ))}
                            </div>
                        </div>
                    )}
                </section>

                {data.layout && (
                    <section class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100" id="layout">
                        <h2 class="text-2xl font-bold text-marmol-navy mb-6">Планировка</h2>
                        <div class="flex flex-col md:flex-row gap-8">
                            
                            <div class="w-full md:w-1/3">
                                <ul class="space-y-0 divide-y divide-gray-100 text-sm">
                                    {data.layout.map(room => (
                                        <li class="flex justify-between py-3">
                                            <span class="text-gray-600">{room.name}</span>
                                            <span class="font-bold text-marmol-navy">{room.area} м²</span>
                                        </li>
                                    ))}
                                    <li class="flex justify-between py-3 bg-gray-50 px-2 rounded mt-2 font-bold text-marmol-navy">
                                        <span>Общая площадь</span>
                                        <span>{data.area} м²</span>
                                    </li>
                                </ul>
                            </div>

                            <PlanViewer 
                               image={data.plan}  
                               images={data.plans}
                               client:load 
                            />

                        </div>
                    </section>
                )}

                {data.gallery && data.gallery.length > 0 && (
                    <section>
                        <ProjectGallery images={data.gallery} client:visible />
                    </section>
                )}
                <!-- Здесь мы передаем fixPrice внутрь компонента -->
                <section id="pricing">
                    <ProjectPricing 
                        area={data.area} 
                        projectTitle={data.title} 
                        fixPrice={data.fixPrice} 
                        priceCategory={data.priceCategory}  
                        client:visible 
                    />
                </section>

            </div>

            <!-- ПРАВАЯ КОЛОНКА (Липкий сайдбар) -->
            <div class="hidden lg:block relative">
                <div class="sticky top-28 space-y-6">
                    <div class="bg-white rounded-2xl p-8 shadow-xl border border-gray-100">
                        <p class="text-gray-400 text-xs uppercase tracking-widest mb-2">Ориентировочная цена</p>
                        <div class="flex items-baseline gap-2 mb-1">
                            <span class="text-lg text-marmol-gold font-bold">от</span>
                            <span class="text-4xl font-bold text-marmol-navy">{formatPrice(totalPrice)}</span>
                            <span class="text-sm font-bold text-gray-600">{globalPricing.currency}</span>
                        </div>
                        {/* @ts-ignore */}
                        <p class="text-xs text-gray-400 mb-6">В комплектации "{globalPricing.packages[categoryKey]?.title}"</p>
                        <button 
                            id="sidebar-cta-btn"
                            class="w-full bg-marmol-navy text-white font-bold uppercase tracking-widest py-4 rounded-lg hover:bg-marmol-gold hover:text-marmol-navy transition-all duration-300 shadow-lg cursor-pointer mb-4"
                        >
                            Рассчитать стоимость
                        </button>
                        <p class="text-[10px] text-gray-400 text-center leading-tight">
                            Расчет ни к чему не обязывает. Отправим подробную смету в мессенджер.
                        </p>
                    </div>
                    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex items-center space-x-4">
                    <div class="w-12 h-12 rounded-full bg-gray-50 border border-gray-200 overflow-hidden flex items-center justify-center shrink-0">
                        <img 
                            src="/infoLogo.png"
                            loading="lazy" 
                            alt="Marmol House консультация" 
                            class="w-full h-full object-contain p-2" 
                        />
                    </div>
                    <div>
                        <p class="text-sm font-bold text-marmol-navy">Есть вопросы?</p>
                        <a href="tel:+375291845481" class="text-marmol-gold font-bold hover:underline">+375 (29) 184-54-81</a>
                    </div>
                </div>
                </div>
            </div>

        </div>
    </div>
    
    <!-- МОБИЛЬНАЯ ПЛАШКА -->
    <div class="lg:hidden fixed bottom-0 left-0 w-full bg-white border-t border-gray-200 p-4 shadow-[0_-5px_20px_rgba(0,0,0,0.1)] z-40 flex justify-between items-center">
        <div>
            <p class="text-xs text-gray-400 uppercase">Цена от</p>
            <p class="text-xl font-bold text-marmol-navy">{formatPrice(totalPrice)} {globalPricing.currency}</p>
        </div>
        <button 
            id="mobile-cta-btn" 
            class="bg-marmol-gold text-marmol-navy font-bold text-xs uppercase tracking-wider py-3 px-6 rounded hover:bg-white transition-all shadow-md cursor-pointer"
        >
            Расчет
        </button>
    </div>

  </main>
</Layout>

<script>
    import { isModalOpen, formComment } from '../../store/modalStore';

    // Единый глобальный слушатель (паттерн делегирования)
    document.addEventListener('click', (e) => {
        // @ts-ignore
        const target = e.target.closest('#sidebar-cta-btn, #mobile-cta-btn');
        
        if (target) {
            const titleElement = document.querySelector('h1');
            const projectTitle = titleElement ? titleElement.innerText : 'Проект';
            
            formComment.set(`Здравствуйте! Меня интересует проект "${projectTitle}".`);
            isModalOpen.set(true);
        }
    });
</script>