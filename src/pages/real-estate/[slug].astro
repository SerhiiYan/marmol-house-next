---
// src/pages/real-estate/[slug].astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// Компоненты
import ProjectGallery from '../../components/project/ProjectGallery.jsx';
import PlanViewer from '../../components/project/PlanViewer.jsx';
import ConsultationModal from '../../components/ui/ConsultationModal.jsx';

export async function getStaticPaths() {
  const items = await getCollection('real-estate');
  return items.map(item => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const data = item.data;

// Хелперы
const formatPrice = (p) => p.toLocaleString('ru-RU');
const getStatusText = (status) => {
    switch (status) {
        case 'available': return { text: 'В продаже', color: 'bg-green-500' };
        case 'reserved': return { text: 'Забронирован', color: 'bg-orange-400' };
        case 'sold': return { text: 'Продан', color: 'bg-gray-400' };
        default: return { text: 'В продаже', color: 'bg-green-500' };
    }
};
const statusInfo = getStatusText(data.status);

// --- ЧИСТОЕ SEO ---
// 1. Формируем кликабельный Title
const pageTitle = `Купить ${data.title} в Гродно | Marmol House`;

// 2. Генерируем Description (если нет в базе, собираем из фактов)
const generatedDesc = `Продается ${data.title}. Площадь: ${data.specs.area} м², участок: ${data.location.plotSize} сот. Адрес: ${data.location.city}, ${data.location.address}. Цена: ${formatPrice(data.price)} ${data.currency || 'BYN'}.`;
const pageDescription = data.description ? `${data.description.slice(0, 155)}...` : generatedDesc;

// 3. Микроразметка (Google будет выводить цену в результатах поиска)
const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": data.title,
  "description": pageDescription,
  "image": data.mainImage,
  "offers": {
    "@type": "Offer",
    "price": data.price,
    "priceCurrency": data.currency || "BYN",
    "availability": data.status === "available" ? "https://schema.org/InStock" : "https://schema.org/SoldOut",
    "url": `https://marmolhouse.by/real-estate/${item.id}`
  }
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <main class="bg-gray-50 pb-24">
    
    <div class="relative h-[60vh] min-h-[400px] w-full overflow-hidden">
        <img 
            src={data.mainImage} 
            alt={`Фото объекта на продажу: ${data.title}`} 
            loading="eager"
            class={`w-full h-full object-cover ${data.status === 'sold' ? 'grayscale' : ''}`}
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-black/30"></div>
        
        <div class="absolute bottom-0 left-0 w-full p-6 pb-24 md:p-12 md:pb-12">
            <div class="max-w-7xl mx-auto">
                <div class="flex items-center gap-3 mb-4">
                    <span class={`text-white text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-sm shadow-md ${statusInfo.color}`}>
                        {statusInfo.text}
                    </span>
                    <span class="bg-white/20 backdrop-blur-md text-white text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-sm">
                        {data.location.district || data.location.city}
                    </span>
                </div>
                
                <h1 class="text-4xl md:text-6xl font-bold text-white mb-2">{data.title}</h1>
                <p class="text-gray-300 text-lg flex items-center gap-2 mt-2">
                    <svg aria-hidden="true" class="w-5 h-5 text-marmol-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    {data.location.address}
                </p>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-10 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <div class="lg:col-span-2 space-y-12">
                
                <section class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
                    <h2 class="text-2xl font-bold text-marmol-navy mb-6">Об объекте</h2>
                    
                    <dl class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8 border-b border-gray-100 pb-8">
                        <div>
                            <dt class="text-xs text-gray-400 uppercase mb-1">Площадь</dt>
                            <dd class="font-bold text-marmol-navy text-xl">{data.specs.area} м²</dd>
                        </div>
                        <div>
                            <dt class="text-xs text-gray-400 uppercase mb-1">Комнат</dt>
                            <dd class="font-bold text-marmol-navy text-xl">{data.specs.rooms}</dd>
                        </div>
                        <div>
                            <dt class="text-xs text-gray-400 uppercase mb-1">Материал</dt>
                            <dd class="font-bold text-marmol-navy text-xl">{data.technology === 'block' ? 'Блок' : 'Каркас'}</dd>
                        </div>
                        <div>
                            <dt class="text-xs text-gray-400 uppercase mb-1">Участок</dt>
                            <dd class="font-bold text-marmol-navy text-xl">{data.location.plotSize} сот.</dd>
                        </div>
                    </dl>

                    <div class="prose prose-slate text-gray-600 leading-relaxed mb-8">
                        <p>{data.description}</p>
                        {data.wallMaterial && <p class="text-sm border-l-2 border-marmol-gold pl-3"><strong>Стены:</strong> {data.wallMaterial}</p>}
                    </div>

                    {data.features && (
                        <div class="flex flex-wrap gap-3">
                            {data.features.map(f => (
                                <span class="px-4 py-2 bg-gray-50 text-marmol-navy text-sm font-medium rounded-lg border border-gray-200 flex items-center">
                                    <svg aria-hidden="true" class="w-4 h-4 text-green-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                                    {f}
                                </span>
                            ))}
                        </div>
                    )}
                </section>

                {/* ПЛАНИРОВКА */}
                {data.layout && (
                    <section class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100" id="layout">
                        <h2 class="text-2xl font-bold text-marmol-navy mb-6">Планировка</h2>
                        <div class="flex flex-col md:flex-row gap-8">
                            <div class="w-full md:w-1/3">
                                <ul class="space-y-0 divide-y divide-gray-100 text-sm">
                                    {data.layout.map(room => (
                                        <li class="flex justify-between py-3">
                                            <span class="text-gray-600">{room.name}</span>
                                            <span class="font-bold text-marmol-navy">{room.area} м²</span>
                                        </li>
                                    ))}
                                    <li class="flex justify-between py-4 bg-gray-50 px-3 rounded-lg mt-4 border border-gray-100">
                                        <span class="font-bold text-marmol-navy">Общая площадь</span>
                                        <span class="font-bold text-marmol-navy text-lg">{data.specs.area} м²</span>
                                    </li>
                                </ul>
                            </div>
                            <PlanViewer image={data.plans?.[0]} client:visible />
                        </div>
                    </section>
                )}

                {/* ГАЛЕРЕЯ */}
                {data.gallery && (
                    <section>
                        <ProjectGallery images={data.gallery} client:visible />
                    </section>
                )}

            </div>

            <div class="hidden lg:block relative">
                <div class="sticky top-28 space-y-6">
                    <div class="bg-white rounded-2xl p-8 shadow-xl border border-gray-100">
                        
                        <div class="mb-6">
                            <p class="text-gray-400 text-xs uppercase tracking-widest mb-1">Стоимость объекта</p>
                            <div class="flex items-baseline gap-2">
                                <span class="text-4xl font-bold text-marmol-navy">{formatPrice(data.price)}</span>
                                <span class="text-lg font-bold text-gray-600">{data.currency || 'BYN'}</span>
                            </div>
                        </div>

                        {data.status === 'available' ? (
                            <button id="sidebar-cta-btn" class="w-full bg-marmol-navy cursor-pointer text-white font-bold uppercase tracking-widest py-4 rounded-lg hover:bg-marmol-gold hover:text-marmol-navy transition-all duration-300 shadow-lg mb-4">
                                Записаться на просмотр
                            </button>
                        ) : (
                            <button disabled class="w-full bg-gray-200 text-gray-400 font-bold uppercase tracking-widest py-4 rounded-lg cursor-not-allowed mb-4">
                                {statusInfo.text}
                            </button>
                        )}
                        
                        <div class="space-y-3 text-sm text-gray-600 pt-4 border-t border-gray-100">
                            <p class="flex items-center"><svg aria-hidden="true" class="w-4 h-4 mr-2 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> Участок в частной собственности</p>
                            <p class="flex items-center"><svg aria-hidden="true" class="w-4 h-4 mr-2 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> Полный пакет документов</p>
                        </div>
                    </div>

                    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex items-center space-x-4">
                        <div class="w-12 h-12 rounded-full bg-gray-50 border border-gray-200 overflow-hidden flex items-center justify-center">
                            <img 
                                src="/infoLogo.png"
                                loading="lazy" 
                                alt="Консультация Marmol House" 
                                class="w-full h-full object-contain p-2" 
                            />
                        </div>
                        <div>
                            <p class="text-sm font-bold text-marmol-navy">Вопросы по объекту?</p>
                            <a href="tel:+375291845481" class="text-marmol-gold font-bold hover:underline">+375 (29) 184-54-81</a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
    
    <div class="lg:hidden fixed bottom-0 left-0 w-full bg-white border-t border-gray-200 p-4 shadow-2xl z-40 flex justify-between items-center">
        <div>
            <p class="text-xl font-bold text-marmol-navy">{formatPrice(data.price)} {data.currency}</p>
            <p class="text-[10px] text-gray-400 uppercase">{statusInfo.text}</p>
        </div>
        {data.status === 'available' ? (
            <button id="mobile-cta-btn" class="bg-marmol-gold text-marmol-navy font-bold text-xs uppercase tracking-wider py-3 px-6 rounded shadow-md">
                На просмотр
            </button>
        ) : (
            <span class="text-gray-400 font-bold text-sm uppercase px-4">Нет в наличии</span>
        )}
    </div>

  </main>
  
  <ConsultationModal client:load />

</Layout>

<script>
    import { isModalOpen, formComment } from '../../store/modalStore';

    function setupButtons() {
        const titleElement = document.querySelector('h1');
        const title = titleElement ? titleElement.innerText : 'Объект';
        const btns = ['sidebar-cta-btn', 'mobile-cta-btn'];

        btns.forEach(id => {
            const btn = document.getElementById(id);
            if (btn) {
                // Клонируем кнопку
                const newBtn = btn.cloneNode(true);
                
                // Добавляем проверку на parentNode, чтобы редактор кода не ругался
                if (btn.parentNode) {
                    btn.parentNode.replaceChild(newBtn, btn);
                }
                
                // Вешаем слушатель на новую, чистую кнопку
                newBtn.addEventListener('click', () => {
                    formComment.set(`Здравствуйте! Хочу записаться на просмотр объекта: "${title}".`);
                    isModalOpen.set(true);
                });
            }
        });
    }
    
    // Запускаем при инициализации страницы
    document.addEventListener('astro:page-load', setupButtons);
    setupButtons();
</script>