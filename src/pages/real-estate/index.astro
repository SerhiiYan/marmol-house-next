---
// src/pages/real-estate/index.astro
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. ПОЛУЧАЕМ ОБЪЕКТЫ
// Сортируем: сначала 'available', потом 'reserved', в конце 'sold'
const realEstateItems = (await getCollection('real-estate')).sort((a, b) => {
  const statusOrder = { available: 1, reserved: 2, sold: 3 };
  return statusOrder[a.data.status] - statusOrder[b.data.status];
});

// Хелперы для статусов (Цвета и Текст)
const getStatusBadge = (status) => {
  switch (status) {
    case 'available': return { text: 'В продаже', class: 'bg-green-500 text-white' };
    case 'reserved': return { text: 'Бронь', class: 'bg-orange-400 text-white' };
    case 'sold': return { text: 'Продано', class: 'bg-gray-400 text-white' };
    default: return { text: 'В продаже', class: 'bg-green-500 text-white' };
  }
};

// Хелпер для готовности
const getReadinessText = (type) => {
    const map = {
        'box': 'Коробка (Черновая)',
        'white-box': 'Под чистовую',
        'turnkey': 'С ремонтом'
    };
    return map[type] || type;
};

// SEO Данные
const pageTitle = "Купить готовый дом в Гродно | Недвижимость Marmol House";
const pageDescription = "Продажа готовых коттеджей и домов с участком от застройщика Marmol House. Лучшие локации в Гродно и пригороде. Ключи в день сделки, без ожидания строительства.";

// Микроразметка Schema.org
const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Продажа готовых домов в Гродно от застройщика",
  "description": pageDescription,
  "numberOfItems": realEstateItems.length,
  "itemListElement": realEstateItems.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "url": `https://marmolhouse.by/real-estate/${item.id}`,
    "name": item.data.title
  }))
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <main class="bg-gray-50 min-h-screen pt-32 pb-24 relative overflow-hidden">
    
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-marmol-gold/5 rounded-full blur-3xl pointer-events-none -translate-y-1/2 translate-x-1/3"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-2">
            <span class="w-2 h-2 rounded-full bg-marmol-gold"></span>
            <p class="text-xs font-bold uppercase tracking-widest text-gray-400">Marmol Real Estate</p>
        </div>
        <h1 class="text-4xl md:text-5xl font-sans font-bold text-marmol-navy mb-4">
            Готовые дома в наличии
        </h1>
        <p class="text-gray-500 max-w-2xl text-lg font-light">
            Объекты с участками в лучших локациях. Без ожидания строительства — получаете ключи в день сделки.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        {realEstateItems.map(item => {
            const data = item.data;
            const statusStyle = getStatusBadge(data.status);
            const isSold = data.status === 'sold';

            return (
                <a href={`/real-estate/${item.id}`} class={`group block bg-white rounded-2xl overflow-hidden shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] hover:shadow-[0_8px_30px_-4px_rgba(15,23,42,0.1)] transition-all duration-500 border border-gray-100 relative flex flex-col ${isSold ? 'opacity-75 hover:opacity-100 grayscale hover:grayscale-0' : ''}`}>
                    
                    {/* КАРТИНКА */}
                    <div class="relative h-72 overflow-hidden bg-gray-200 shrink-0">
                        {/* SEO: Динамический ALT */}
                        <img 
                            src={data.mainImage} 
                            alt={`Купить готовый дом: ${data.title}`} 
                            loading="lazy"
                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                        />
                        
                        {/* СТАТУС */}
                        <div class={`absolute top-4 left-4 px-3 py-1.5 rounded-md text-[10px] font-bold uppercase tracking-widest shadow-sm z-10 ${statusStyle.class}`}>
                            {statusStyle.text}
                        </div>

                        {/* УЧАСТОК */}
                        <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-md px-3 py-1.5 rounded-md text-[10px] font-bold text-marmol-navy uppercase tracking-widest shadow-sm z-10 flex items-center">
                            <svg class="w-3 h-3 mr-1 text-marmol-gold" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            {data.location.plotSize} сот.
                        </div>

                        <div class="absolute inset-0 bg-gradient-to-t from-marmol-navy/80 via-transparent to-transparent opacity-60"></div>
                        
                        {/* Адрес */}
                        <div class="absolute bottom-4 left-4 text-white">
                            <p class="text-xs font-bold uppercase tracking-wider opacity-80 mb-1">
                                {data.location.city}
                            </p>
                            <div class="flex items-center">
                                <svg class="w-4 h-4 mr-1 text-marmol-gold" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
                                <span class="font-bold truncate max-w-[250px]">{data.location.district || data.location.address}</span>
                            </div>
                        </div>
                    </div>

                    {/* ИНФОРМАЦИЯ */}
                    <div class="p-6 flex flex-col grow">
                        
                        <div class="mb-4">
                            <h3 class="text-xl font-bold text-marmol-navy leading-tight mb-2 group-hover:text-marmol-gold transition-colors line-clamp-2">
                                {data.title}
                            </h3>
                            <p class="text-xs text-gray-500 font-medium bg-gray-50 border border-gray-100 inline-block px-2 py-1 rounded">
                                {getReadinessText(data.readiness)}
                            </p>
                        </div>

                        <div class="grow"></div>

                        {/* Семантически правильный список характеристик (dl) */}
                        <dl class="grid grid-cols-3 gap-2 py-4 border-t border-b border-gray-50 mb-5 mt-2">
                            <div class="flex flex-col text-center">
                                <dt class="text-[10px] text-gray-400 uppercase tracking-widest mb-0.5">Площадь</dt>
                                <dd class="font-bold text-marmol-navy">{data.specs.area} м²</dd>
                            </div>
                            <div class="flex flex-col text-center border-l border-gray-100">
                                <dt class="text-[10px] text-gray-400 uppercase tracking-widest mb-0.5">Комнат</dt>
                                <dd class="font-bold text-marmol-navy">{data.specs.rooms}</dd>
                            </div>
                            <div class="flex flex-col text-center border-l border-gray-100">
                                <dt class="text-[10px] text-gray-400 uppercase tracking-widest mb-0.5">Спален</dt>
                                <dd class="font-bold text-marmol-navy">{data.specs.bedrooms}</dd>
                            </div>
                        </dl>

                        {/* ЦЕНА */}
                        <div class="flex items-center justify-between">
                            <div class="flex flex-col">
                                {data.oldPrice && (
                                    <span class="text-xs text-gray-400 line-through mb-0.5">
                                        {data.oldPrice.toLocaleString('ru-RU')} {data.currency}
                                    </span>
                                )}
                                <p class="text-2xl font-bold text-marmol-navy leading-none">
                                    {data.price.toLocaleString('ru-RU')} <span class="text-sm font-normal text-gray-500">{data.currency}</span>
                                </p>
                            </div>
                            
                            <div class="w-10 h-10 rounded-full border border-gray-200 text-marmol-navy flex items-center justify-center group-hover:bg-marmol-navy group-hover:border-marmol-navy group-hover:text-white transition-all">
                                <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 group-hover:translate-x-0.5 transition-transform">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                                </svg>
                            </div>
                        </div>

                    </div>
                </a>
            )
        })}

        {realEstateItems.length === 0 && (
            <div class="col-span-full py-20 text-center bg-white rounded-2xl border border-gray-100 shadow-sm">
                <p class="text-gray-500 text-lg mb-2">В данный момент все готовые объекты распроданы.</p>
                <a href="/projects" class="text-marmol-gold font-bold hover:text-marmol-navy transition-colors underline underline-offset-4">Подобрать проект для строительства</a>
            </div>
        )}

      </div>
    </div>
  </main>
</Layout>