<style>
    @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @keyframes drop-line {
        0% { top: -100%; }
        50% { top: 100%; }
        100% { top: 100%; }
    }
    .animate-fade-in-up {
        animation: fade-in-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .animate-drop-line {
        animation: drop-line 2s cubic-bezier(0.77, 0, 0.175, 1) infinite;
    }
</style>

<script>
    import { isModalOpen, formComment } from '../../store/modalStore';
    
    // Обернуто в функцию для поддержки Astro View Transitions
    const setupModals = () => {
        const setupBtn = (id) => {
            const btn = document.getElementById(id);
            if (btn) {
                // Предотвращение дублирования
                const newBtn = btn.cloneNode(true);
                if (btn.parentNode) btn.parentNode.replaceChild(newBtn, btn);
                
                newBtn.addEventListener('click', () => {
                    formComment.set(`Интересует строительство для бизнеса (Под ключ).`);
                    isModalOpen.set(true);
                });
            }
        };
        setupBtn('biz-consult-btn-desk');
        setupBtn('biz-consult-btn-mob');
    };

    document.addEventListener('astro:page-load', setupModals);
    setupModals();
</script>