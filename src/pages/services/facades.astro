---
// src/pages/services/facades.astro
import Layout from '../../layouts/Layout.astro';

// SEO Мета-данные
const pageTitle = "Премиум фасады: Клинкер, Камень, Керамика | Marmol House";
const pageDescription = "Проектирование и монтаж вентилируемых фасадов премиум-класса. Облицовка клинкерным кирпичом, натуральным камнем и крупноформатной керамикой в Гродно и Минске.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Премиальная облицовка фасадов",
  "provider": {
    "@type": "ConstructionBusiness",
    "name": "Marmol House"
  },
  "areaServed": ["Гродно", "Минск"],
  "description": pageDescription
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <main class="bg-white">

    <section class="relative h-screen flex items-center md:items-end pb-0 md:pb-48 bg-marmol-navy overflow-hidden">
        
        <div class="absolute inset-0 z-0 bg-marmol-navy">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white/5 via-transparent to-transparent opacity-70"></div>
            <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 30px 30px;"></div>
        </div>

        <div class="block absolute top-0 right-0 h-full w-full md:w-3/5 z-0 pointer-events-none">
            <img src="/brick-offer/brick.webp" class="w-full h-full object-cover opacity-30 saturate-0" alt="" aria-hidden="true" loading="eager" />
            <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-marmol-navy via-marmol-navy/90 md:via-marmol-navy/80 to-marmol-navy/60 md:to-transparent"></div>
        </div>

        <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row gap-8 items-center md:items-end text-center md:text-left">
                
                <div class="hidden md:flex flex-col items-center gap-6 opacity-0 animate-fade-in-up" style="animation-delay: 0.1s;">
                    <span class="text-gray-500 text-[10px] font-bold uppercase tracking-[0.3em] [writing-mode:vertical-rl] rotate-180">
                        Marmol House
                    </span>
                    <div class="w-[1px] h-40 bg-gradient-to-t from-marmol-gold to-transparent"></div>
                </div>

                <div class="max-w-4xl">
                    <div class="flex items-center justify-center md:justify-start gap-3 mb-6 opacity-0 animate-fade-in-up" style="animation-delay: 0.2s;">
                        <span class="text-marmol-gold text-xs font-bold uppercase tracking-widest">Архитектурная эстетика</span>
                        <div class="hidden md:block h-[1px] w-16 bg-white/10"></div>
                    </div>

                    <h1 class="text-5xl md:text-7xl lg:text-8xl font-sans font-bold text-white mb-8 leading-[1.0] tracking-tight opacity-0 animate-fade-in-up" style="animation-delay: 0.3s;">
                        Премиум <br />
                        отделка <br />
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-marmol-gold via-white/80 to-white/40">фасадов</span>
                    </h1>
                    
                    <p class="text-lg md:text-xl text-gray-400 font-light leading-relaxed max-w-xl md:border-l md:border-white/10 md:pl-8 opacity-0 animate-fade-in-up" style="animation-delay: 0.5s;">
                        Инженерные решения для фасадов премиум-класса. <br class="hidden md:block"/>
                        Клинкер. Натуральный камень. Керамика.
                    </p>
                </div>
            </div>
        </div>

        <div class="hidden md:flex absolute bottom-10 right-16 flex-col items-center gap-4 opacity-30 hover:opacity-100 transition-opacity">
            <div class="h-24 w-[1px] bg-white/10 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-1/2 bg-marmol-gold animate-drop-line"></div>
            </div>
            <span class="text-[10px] text-white uppercase tracking-widest [writing-mode:vertical-rl] rotate-180">Scroll</span>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8 items-start">
                
                <div class="md:col-span-5 relative">
                    <h2 class="text-4xl md:text-5xl font-bold text-marmol-navy leading-tight mb-6">
                        Больше, чем <br/> просто стена
                    </h2>
                    <div class="w-16 h-1 bg-marmol-gold"></div>
                </div>

                <div class="md:col-span-7">
                    <p class="text-xl text-gray-800 font-light leading-relaxed mb-6">
                        «Фасад — это инвестиция в будущее вашего дома. Наша ключевая компетенция — сложные инженерные решения: клинкер, натуральный камень и крупноформатная керамика. Такие фасады служат более 100 лет без <strong>необходимости ремонта.</strong>
                    </p>
                    <p class="text-gray-500 leading-relaxed">
                        Однако главным для нас остается видение заказчика. Мы работаем с любыми видами отделки, включая декоративные штукатурки («корник», «американка»), обеспечивая безупречное исполнение вне зависимости от выбранного материала.
                    </p>
                </div>

            </div>
        </div>
    </section>

    <section class="py-24 bg-gray-900 text-white relative overflow-hidden">
        <div class="absolute right-0 top-0 text-[15rem] md:text-[25rem] font-bold text-white/[0.02] leading-none select-none pointer-events-none -translate-y-1/4 translate-x-1/4">01</div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                
                <div class="relative aspect-[4/5] md:aspect-square w-full rounded-sm overflow-hidden group shadow-2xl">
                    <img src="/brick-offer/brick2.webp" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" alt="Облицовка фасада дома клинкерным кирпичом" loading="lazy">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                    <div class="absolute bottom-8 left-8">
                        <span class="text-marmol-gold text-xs font-bold uppercase tracking-[0.2em] mb-2 block">Керамический кирпич</span>
                        <span class="text-white text-2xl font-serif italic">Графит</span>
                    </div>
                </div>

                <div>
                    <h3 class="text-4xl md:text-5xl font-bold mb-8">Клинкерный кирпич</h3>
                    
                    <div class="space-y-8">
                        <p class="text-gray-400 text-lg leading-relaxed border-l border-marmol-gold pl-6">
                            Эталон надежности. Мы используем кирпич из уникальной глины Ненорово-Филимоновского месторождения. Отсутствие карбонатных включений гарантирует защиту от высолов, а технология «флеш-обжига» создает неповторимую игру цвета.
                            Керамический кирпич от ООО «Вышневолоцкая Керамика» изготавливается современным, зарекомендовавшим себя, методом на оборудовании итальянских фирм «Piccinini inpianti» и «Cosmec».
                        </p>

                        <div class="grid grid-cols-2 gap-6 pt-4">
                            <div class="p-4 border border-white/10 rounded-lg hover:bg-white/5 transition-colors">
                                <div class="text-2xl font-bold text-white mb-1">М200-250</div>
                                <div class="text-[10px] text-gray-500 uppercase tracking-widest">Марка прочности</div>
                            </div>
                            <div class="p-4 border border-white/10 rounded-lg hover:bg-white/5 transition-colors">
                                <div class="text-2xl font-bold text-white mb-1">F200</div>
                                <div class="text-[10px] text-gray-500 uppercase tracking-widest">Морозостойкость</div>
                            </div>
                            <div class="p-4 border border-white/10 rounded-lg hover:bg-white/5 transition-colors col-span-2">
                                <div class="text-lg font-bold text-white mb-1">Без высолов</div>
                                <div class="text-[10px] text-gray-500 uppercase tracking-widest">Технология массоподготовки глины</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 bg-gray-50 text-marmol-navy relative overflow-hidden">
        <div class="absolute left-0 top-0 text-[15rem] md:text-[25rem] font-bold text-black/[0.02] leading-none select-none pointer-events-none -translate-y-1/4 -translate-x-1/4">02</div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                
                <div class="order-2 lg:order-1">
                    <h3 class="text-4xl md:text-5xl font-bold mb-8">Натуральный камень</h3>
                    
                    <div class="space-y-8">
                        <p class="text-gray-600 text-lg leading-relaxed border-l border-marmol-navy pl-6">
                            Фасад, превращающий дом в резиденцию. Травертин, известняк или гранит. Благородное старение материала и уникальный рисунок, созданный природой, который невозможно подделать.
                        </p>

                        <div class="grid grid-cols-1 gap-4 pt-4">
                            <div class="flex items-center p-4 bg-white shadow-sm rounded-lg border border-gray-100">
                                <span class="w-2 h-2 bg-marmol-navy rounded-full mr-4"></span>
                                <div>
                                    <div class="font-bold text-marmol-navy">Травертин</div>
                                    <div class="text-xs text-gray-400">Теплая фактура с уникальными порами</div>
                                </div>
                            </div>
                            <div class="flex items-center p-4 bg-white shadow-sm rounded-lg border border-gray-100">
                                <span class="w-2 h-2 bg-marmol-navy rounded-full mr-4"></span>
                                <div>
                                    <div class="font-bold text-marmol-navy">Гранит & Известняк</div>
                                    <div class="text-xs text-gray-400">Максимальная прочность и монументальность</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="relative aspect-[4/5] md:aspect-square w-full rounded-sm overflow-hidden group shadow-2xl order-1 lg:order-2">
                    <img src="/brick-offer/stone-facade.webp" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" alt="Отделка фасада частного дома натуральным камнем" loading="lazy">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
                    <div class="absolute bottom-8 right-8 text-right">
                        <span class="text-white/80 text-xs font-bold uppercase tracking-[0.2em] mb-2 block">Материал</span>
                        <span class="text-white text-2xl font-serif italic">Natural Stone</span>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <section class="py-24 bg-gray-900 text-white relative overflow-hidden">
        <div class="absolute right-0 top-0 text-[15rem] md:text-[25rem] font-bold text-white/[0.02] leading-none select-none pointer-events-none -translate-y-1/4 translate-x-1/4">03</div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                
                <div class="relative aspect-[4/5] md:aspect-square w-full rounded-sm overflow-hidden group shadow-2xl">
                    <img src="/brick-offer/ceramic-facade.webp" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" alt="Монтаж фасада из крупноформатной керамики" loading="lazy">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                    <div class="absolute bottom-8 left-8">
                        <span class="text-marmol-gold text-xs font-bold uppercase tracking-[0.2em] mb-2 block">Стиль</span>
                        <span class="text-white text-2xl font-serif italic">High-Tech</span>
                    </div>
                </div>

                <div>
                    <h3 class="text-4xl md:text-5xl font-bold mb-8">Крупноформатная керамика</h3>
                    
                    <div class="space-y-8">
                        <p class="text-gray-400 text-lg leading-relaxed border-l border-marmol-gold pl-6">
                            Архитектура будущего. Огромные панели размером до 3 метров создают эффект сплошной стены без видимых швов. Идеальное решение для современной архитектуры с плоскими кровлями.
                        </p>

                        <div class="pt-6">
                            <div class="grid grid-cols-2 gap-4 mb-6">
                                <div class="px-5 py-3 border border-white/20 rounded text-center text-sm tracking-wider">Laminam</div>
                                <div class="px-5 py-3 border border-white/20 rounded text-center text-sm tracking-wider">Arch-Skin</div>
                            </div>
                            <div class="flex items-center gap-4 text-gray-400 text-sm">
                                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-marmol-gold"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" /></svg>
                                <span>Формат до 3000 x 1000 мм</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 bg-gray-50 text-marmol-navy relative overflow-hidden">
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 40px 40px;"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-sans font-bold mb-4">Инженерный стандарт</h2>
                <p class="text-gray-500 max-w-2xl mx-auto">
                    Мы не просто «лепим» фасад. Мы создаем сложную инженерную систему, которая защищает ваш дом.
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                
                <div class="group relative p-8 bg-white border border-gray-200 rounded-xl hover:shadow-xl hover:border-marmol-gold transition-all duration-300">
                    <div class="absolute top-4 right-4 text-6xl font-bold text-gray-100 group-hover:text-marmol-gold/10 transition-colors select-none">01</div>
                    <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-6 text-marmol-navy group-hover:scale-110 transition-transform">
                        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
                    </div>
                    <h4 class="text-xl font-bold text-marmol-navy mb-3">КМД Проект</h4>
                    <p class="text-gray-500 text-sm leading-relaxed">
                        Детальная раскладка каждого элемента фасада. Мы заранее знаем, где пройдет шов, чтобы минимизировать обрезки дорогого материала.
                    </p>
                </div>

                <div class="group relative p-8 bg-white border border-gray-200 rounded-xl hover:shadow-xl hover:border-marmol-gold transition-all duration-300">
                    <div class="absolute top-4 right-4 text-6xl font-bold text-gray-100 group-hover:text-marmol-gold/10 transition-colors select-none">02</div>
                    <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-6 text-marmol-navy group-hover:scale-110 transition-transform">
                         <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" /></svg>
                    </div>
                    <h4 class="text-xl font-bold text-marmol-navy mb-3">Подсистема</h4>
                    <p class="text-gray-500 text-sm leading-relaxed">
                        Только сертифицированные кронштейны из нержавеющей стали или алюминия. Каркас, который держит нагрузку 50+ лет без коррозии.
                    </p>
                </div>

                <div class="group relative p-8 bg-white border border-gray-200 rounded-xl hover:shadow-xl hover:border-marmol-gold transition-all duration-300">
                    <div class="absolute top-4 right-4 text-6xl font-bold text-gray-100 group-hover:text-marmol-gold/10 transition-colors select-none">03</div>
                    <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-6 text-marmol-navy group-hover:scale-110 transition-transform">
                         <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.703.127 1.243.725 1.215 2.755 1.215 2.755A11.952 11.952 0 0117.7 17.7M16.85 3.527t.108 2.112A25.22 25.22 0 014.53 8.688L3.905 18.06" /></svg>
                    </div>
                    <h4 class="text-xl font-bold text-marmol-navy mb-3">Монтаж</h4>
                    <p class="text-gray-500 text-sm leading-relaxed">
                        Собственные штатные бригады. Баварская кладка, скрытое крепление керамики, идеальные швы и чистота на участке.
                    </p>
                </div>

            </div>
        </div>
    </section>

  </main>
</Layout>

<style>
    @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @keyframes drop-line {
        0% { top: -100%; }
        50% { top: 100%; }
        100% { top: 100%; }
    }
    
    .animate-fade-in-up {
        animation: fade-in-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .animate-drop-line {
        animation: drop-line 2s cubic-bezier(0.77, 0, 0.175, 1) infinite;
    }
</style>