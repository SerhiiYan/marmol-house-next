<style>
    @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @keyframes drop-line {
        0% { top: -100%; }
        50% { top: 100%; }
        100% { top: 100%; }
    }
    .animate-fade-in-up {
        animation: fade-in-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .animate-drop-line {
        animation: drop-line 2s cubic-bezier(0.77, 0, 0.175, 1) infinite;
    }
</style>

<script>
    // Обернули логику в функцию для совместимости с Astro View Transitions
    const initBlockTabs = () => {
        const btnBase = document.getElementById('btn-base');
        const btnFull = document.getElementById('btn-full');
        const contentBase = document.getElementById('content-base');
        const contentFull = document.getElementById('content-full');
        const tabBg = document.getElementById('tab-bg');

        function switchTab(mode) {
            if (mode === 'base') {
                if (tabBg) tabBg.style.transform = 'translateX(0)';
                
                btnBase?.classList.add('text-white');
                btnBase?.classList.remove('text-gray-500', 'hover:text-marmol-navy');
                
                btnFull?.classList.remove('text-white');
                btnFull?.classList.add('text-gray-500', 'hover:text-marmol-navy');
                
                contentBase?.classList.remove('hidden');
                setTimeout(() => contentBase?.classList.remove('opacity-0'), 10);
                
                contentFull?.classList.add('hidden', 'opacity-0');
            } else {
                if (tabBg) tabBg.style.transform = 'translateX(100%)';
                
                btnFull?.classList.add('text-white');
                btnFull?.classList.remove('text-gray-500', 'hover:text-marmol-navy');
                
                btnBase?.classList.remove('text-white');
                btnBase?.classList.add('text-gray-500', 'hover:text-marmol-navy');
                
                contentFull?.classList.remove('hidden');
                setTimeout(() => contentFull?.classList.remove('opacity-0'), 10);
                
                contentBase?.classList.add('hidden', 'opacity-0');
            }
        }

        // Используем .onclick, чтобы избежать дублирования событий при переходах между страницами
        if (btnBase) btnBase.onclick = () => switchTab('base');
        if (btnFull) btnFull.onclick = () => switchTab('full');
    };

    document.addEventListener('astro:page-load', initBlockTabs);
    initBlockTabs();
</script>