---
// src/layouts/Layout.astro
import '../styles/global.css'; 
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsultationModal from '../components/ui/ConsultationModal.jsx'
import CookieBanner from '../components/ui/CookieBanner.astro';

interface Props {
    title: string;
    description?: string;
    image?: string;
    canonicalURL?: string;
}

const siteDomain = Astro.site ?? 'https://marmolhouse.by';

const { 
    title, 
    description = "Строим каркасные и блочные дома под ключ в Беларуси. Проект в подарок! Работа по 240 и 95 указу. Фиксированная цена. Гарантия 5 лет. Закажите расчет на сайте Marmol House.",
    // Сделал путь относительным по умолчанию, мы его превратим в абсолютный ниже
    image = "/og-image.png", 
    canonicalURL = new URL(Astro.url.pathname, siteDomain).href,
} = Astro.props;

// === НОВОЕ: Железобетонная генерация абсолютного пути для картинки ===
// new URL() автоматически подклеит домен, если image - это относительный путь (например, /images/dom.jpg)
const ogImageURL = new URL(image, siteDomain).href;
---

<!doctype html>
<html lang="ru">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="author" content="Marmol House" />
        <link rel="canonical" href={canonicalURL} />

        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        {/* Подставляем нашу новую переменную ogImageURL */}
        <meta property="og:image" content={ogImageURL} />
        <meta property="og:locale" content="ru_RU" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        {/* И сюда тоже */}
        <meta name="twitter:image" content={ogImageURL} />
        
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
        <slot name="head" />
    </head>
    <body class="bg-marmol-bg text-marmol-navy font-body antialiased">
        <Header />
        <slot />
        <Footer />
        <ConsultationModal client:load /> 
        <CookieBanner />
    </body>
</html>