---
// src/components/ui/Logo.astro
interface Props {
  // Проп, чтобы менять цвет, если фон будет темный
  variant?: 'dark' | 'light';
}

const { variant = 'light' } = Astro.props;

// Если variant='dark', значит фон темный -> текст белый. Иначе - синий.
const mainTextColor = variant === 'dark' ? 'text-white' : 'text-marmol-navy';
const subTextColor = variant === 'dark' ? 'text-marmol-gold' : 'text-marmol-navy';
---

<a href="/" class="group flex flex-col items-center leading-none select-none w-fit">
  <!-- Верхняя строка: MARMOL -->
  <span class={`font-sans font-bold text-2xl uppercase tracking-[0.2em] ${mainTextColor} transition-colors duration-300 group-hover:text-marmol-gold`}>
    Marmol
  </span>
  
  <!-- Нижняя строка: HOUSE -->
  <!-- tracking-[0.6em] делает буквы очень широкими, это выглядит дорого -->
  <span class={`font-sans font-medium text-[0.65rem] uppercase tracking-[0.6em] mt-1 pl-1 ${subTextColor}`}>
    House
  </span>
  
  <!-- Декоративная линия, появляется при наведении -->
  <span class="w-1/2 h-[2px] mt-2 bg-marmol-gold scale-x-0 group-hover:scale-x-100 transition-transform duration-500 ease-out origin-center"></span>
</a>