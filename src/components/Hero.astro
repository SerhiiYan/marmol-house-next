---
// src/components/Hero.astro
import {portfolioCases} from '../data/portfolio.js'
const videoUrl = "/hero-video.mp4";
---

<section class="relative w-full h-screen min-h-[700px] overflow-hidden bg-marmol-navy">
  
  <!-- СЛОИ ФОНА (Видео + Сетка + Градиент) - БЕЗ ИЗМЕНЕНИЙ -->
  <video 
    class="absolute top-0 left-0 w-full h-full object-cover scale-105" 
    autoplay muted loop playsinline
    poster="https://images.unsplash.com/photo-1600596542815-60c37c65b567?q=80&w=2073"
  >
    <source src={videoUrl} type="video/mp4" />
  </video>

  <div class="absolute inset-0 z-[1] opacity-20 pointer-events-none" 
       style="background-image: radial-gradient(rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 30px 30px;">
  </div>
  <div class="absolute inset-0 z-[2] bg-gradient-to-t from-[#0F172A] via-[#0F172A]/50 to-[#0F172A]/30"></div>

  <!-- КОНТЕНТ -->
  <div class="relative z-10 max-w-[1920px] mx-auto px-6 h-full flex flex-col justify-end pb-12 md:pb-24">
    
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-end w-full">
      
      <!-- ЛЕВАЯ ЧАСТЬ -->
      <div class="md:col-span-8 flex flex-col items-start animate-fade-in-up">
        
        <h1 class="font-sans font-medium text-4xl md:text-6xl lg:text-[5rem] leading-[1.1] text-white uppercase tracking-wider mb-8 drop-shadow-2xl">
          Архитектура <br />
          <span class="text-white font-bold">Комфортной жизни</span>
        </h1>

        <!-- Блок описания -->
        <div class="max-w-2xl border-l-2 border-marmol-gold pl-6 mb-12 flex flex-col gap-4 backdrop-blur-sm bg-marmol-navy/10 py-2 rounded-r-xl">
           <p class="text-gray-100 text-lg md:text-xl font-body font-light tracking-wide leading-relaxed shadow-black/50 drop-shadow-md">
             Проектирование и строительство в <strong class="text-white font-medium">Гродно, области и Минске</strong>. Работаем по всей <span class="text-white">Беларуси</span>.
           </p>
           <p class="text-gray-300 text-base md:text-lg font-body leading-relaxed">
             Возводим современные <strong class="text-white font-medium">каркасные и блочные дома</strong>. 
             Создаем уникальный архитектурный облик, реализуя сложные и красивые <strong class="text-white font-medium">фасады из кирпича</strong>.
           </p>
        </div>

        <!-- КНОПКИ ДЕЙСТВИЯ -->
        <div class="flex flex-col md:flex-row gap-5 w-full md:w-auto">
            
            <!-- 1. НОВАЯ КНОПКА (Открыть форму) -->
            <button 
              id="hero-consult-btn"
              class="bg-marmol-gold text-marmol-navy px-8 py-4 font-bold uppercase tracking-widest hover:bg-white transition-all duration-300 shadow-xl shadow-marmol-gold/20 transform hover:-translate-y-1 text-sm md:text-base flex justify-center items-center cursor-pointer"
          >
              Получить консультацию
          </button>

            <!-- 2. Скролл (Второстепенная) -->
            <a href="#projects" class="group flex items-center justify-center md:justify-start space-x-4 text-white hover:text-marmol-gold transition-colors duration-300 py-3 md:py-0">
                <div class="w-10 h-10 md:w-12 md:h-12 rounded-full border border-white/30 flex items-center justify-center group-hover:border-marmol-gold transition-colors bg-white/5 backdrop-blur-md">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 animate-bounce mt-1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                </div>
                <span class="text-sm uppercase tracking-widest font-medium drop-shadow-md">Смотреть проекты</span>
            </a>
        </div>

      </div>

      <!-- ПРАВАЯ ЧАСТЬ (АВТО-СЛАЙДЕР) -->
      <div class="hidden md:flex md:col-span-4 justify-end">
        <div class="relative w-80 h-56 bg-gray-900 overflow-hidden border border-white/20 group cursor-pointer shadow-2xl backdrop-blur-md bg-white/5">
            
            <!-- Генерируем картинки слайдера -->
            {portfolioCases.map((slide, index) => (
                <div 
                    class={`hero-slide absolute inset-0 transition-opacity duration-1000 ease-in-out ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                    data-index={index}
                >
                    <img 
                        src={slide.image} 
                        class="w-full h-full object-cover transition-transform duration-[5000ms] group-hover:scale-110 opacity-90"
                        alt={slide.title}
                    />
                     <div class="absolute bottom-0 left-0 w-full p-4 bg-gradient-to-t from-black/90 to-transparent">
                        <p class="text-white text-xs uppercase tracking-widest mb-1 opacity-70">Реализованный проект</p>
                        <div class="flex justify-between items-center">
                            <span class="text-white font-bold uppercase tracking-wider text-sm">{slide.title}</span>
                        </div>
                    </div>
                </div>
            ))}
            
            <div class="absolute inset-0 border-2 border-marmol-gold/0 group-hover:border-marmol-gold/100 transition-colors duration-300 pointer-events-none z-10"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
    import { isModalOpen, formComment } from '../store/modalStore';

    // 1. ЛОГИКА ОТКРЫТИЯ МОДАЛКИ
    const btn = document.getElementById('hero-consult-btn');
    btn?.addEventListener('click', () => {
        // Устанавливаем текст для ЭТОЙ кнопки
        formComment.set('Здравствуйте! Хочу получить бесплатную консультацию по строительству дома.');
        // Открываем
        isModalOpen.set(true);
    });

    // 2. ЛОГИКА СЛАЙДЕРА
    const slides = document.querySelectorAll('.hero-slide');
    let currentSlide = 0;
    
    // Запускаем только если слайды существуют (на десктопе)
    if (slides.length > 0) {
        setInterval(() => {
            // Скрываем текущий
            slides[currentSlide].classList.remove('opacity-100');
            slides[currentSlide].classList.add('opacity-0');
            
            // Вычисляем следующий
            currentSlide = (currentSlide + 1) % slides.length;
            
            // Показываем следующий
            slides[currentSlide].classList.remove('opacity-0');
            slides[currentSlide].classList.add('opacity-100');
        }, 5000); // каждые 5 секунд
    }
</script>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 1s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>