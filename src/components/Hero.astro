---
// src/components/Hero.astro
import { getCollection } from 'astro:content';

const videoUrl = "/hero-video.mp4";

const allPortfolio = await getCollection('portfolio');
const featuredCases = allPortfolio
  .filter(project => project.data.isHero === true)
  .slice(0, 3);
---

{/* ИСПОЛЬЗУЕМ min-h-[100dvh] ДЛЯ ИДЕАЛЬНОЙ РАБОТЫ НА МОБИЛКАХ */}
<section class="relative w-full min-h-[100dvh] overflow-hidden bg-marmol-navy flex flex-col">
  
  <img 
    src="/hero-mobile.webp" 
    alt="Строительство каркасных и блочных домов в Гродно" 
    class="absolute top-0 left-0 w-full h-full object-cover md:hidden"
  />

  <video 
    class="absolute top-0 left-0 w-full h-full object-cover scale-105 hidden md:block" 
    autoplay muted loop playsinline
    poster="/hero-mobile.webp"
  >
    <source src={videoUrl} type="video/mp4" />
  </video>

  <div class="absolute inset-0 z-[1] opacity-20 pointer-events-none" 
       style="background-image: radial-gradient(rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 30px 30px;">
  </div>
  <div class="absolute inset-0 z-[2] bg-gradient-to-t from-[#0F172A] via-[#0F172A]/50 to-[#0F172A]/30"></div>

  {/* ГЛАВНЫЙ КОНТЕЙНЕР: ДОБАВЛЕН pt-32 (ОТСТУП ОТ ШАПКИ) И ИЗМЕНЕНЫ БОКОВЫЕ ОТСТУПЫ (px-6 для мобилок) */}
  <div class="relative z-10 w-full max-w-[1920px] mx-auto px-6 md:px-24 flex flex-col justify-end flex-grow pt-32 pb-12 md:pb-24">
    
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-end w-full">
      
      <div class="md:col-span-8 flex flex-col items-start animate-fade-in-up">
        
        <h1 class="text-marmol-gold text-xs sm:text-sm md:text-base font-bold uppercase tracking-widest mb-4 drop-shadow-md">
          Строим каркасные и блочные дома под ключ в Гродно
        </h1>
        
        <span class="block font-sans font-medium text-3xl sm:text-4xl md:text-6xl lg:text-[5rem] leading-[1.1] text-white uppercase tracking-wider drop-shadow-2xl mb-6 md:mb-8" aria-hidden="true">
          Архитектура <br />
          <strong class="text-white font-bold font-sans">Комфортной <br class="md:hidden" /> жизни</strong>
        </span>

        <div class="max-w-2xl border-l-2 border-marmol-gold pl-4 md:pl-6 mb-8 md:mb-12 flex flex-col gap-3 md:gap-4 backdrop-blur-sm bg-marmol-navy/10 py-2 rounded-r-xl">
           <p class="text-gray-100 text-base md:text-xl font-body font-light tracking-wide leading-relaxed shadow-black/50 drop-shadow-md">
             Проектирование и строительство в <strong class="text-white font-medium">Гродно, области и Минске</strong>. Работаем по всей <span class="text-white">Беларуси</span>.
           </p>
           <p class="text-gray-300 text-sm md:text-lg font-body leading-relaxed">
             Возводим современные <strong class="text-white font-medium">каркасные и блочные дома</strong>. 
             Создаем уникальный архитектурный облик, реализуя сложные и красивые <strong class="text-white font-medium">фасады из кирпича</strong>.
           </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 sm:gap-5 w-full sm:w-auto">
            <button 
              id="hero-consult-btn"
              class="bg-marmol-gold text-marmol-navy px-6 md:px-8 py-4 font-bold uppercase tracking-widest hover:bg-white transition-all duration-300 shadow-xl shadow-marmol-gold/20 transform hover:-translate-y-1 text-xs md:text-base flex justify-center items-center cursor-pointer w-full sm:w-auto"
          >
              Получить консультацию
          </button>

            <a href="#projects" class="group flex items-center justify-center sm:justify-start space-x-4 text-white hover:text-marmol-gold transition-colors duration-300 py-2 md:py-0">
                <div class="w-10 h-10 md:w-12 md:h-12 rounded-full border border-white/30 flex items-center justify-center group-hover:border-marmol-gold transition-colors bg-white/5 backdrop-blur-md">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 animate-bounce mt-1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                </div>
                <span class="text-xs md:text-sm uppercase tracking-widest font-medium drop-shadow-md">Смотреть проекты</span>
            </a>
        </div>

      </div>

      <div class="hidden md:flex md:col-span-4 justify-end">
        <div class="relative w-80 h-56 bg-gray-900 overflow-hidden border border-white/20 group cursor-pointer shadow-2xl backdrop-blur-md bg-white/5">
            
            {featuredCases.map((project, index) => {
                const data = project.data;
                const projectUrl = `/portfolio/${project.id}`; 

                return (
                <a 
                    href={projectUrl}
                    class={`hero-slide block absolute inset-0 transition-all duration-1000 ease-in-out cursor-pointer ${index === 0 ? 'opacity-100 z-10 pointer-events-auto' : 'opacity-0 z-0 pointer-events-none'}`}
                    data-index={index}
                >
                    <img 
                        src={data.mainImage} 
                        class="w-full h-full object-cover transition-transform duration-[5000ms] group-hover:scale-110 opacity-90"
                        alt={data.title}
                    />
                     <div class="absolute bottom-0 left-0 w-full p-4 bg-gradient-to-t from-black/90 to-transparent">
                        <p class="text-white text-xs uppercase tracking-widest mb-1 opacity-70">Реализованный проект</p>
                        <div class="flex justify-between items-center">
                            <span class="text-white font-bold uppercase tracking-wider text-sm">{data.title}</span>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-marmol-gold">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                            </svg>
                        </div>
                    </div>
                </a>
                )
            })}
            
            <div class="absolute inset-0 border-2 border-marmol-gold/0 group-hover:border-marmol-gold/100 transition-colors duration-300 pointer-events-none z-10"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
    import { isModalOpen, formComment } from '../store/modalStore';

    const btn = document.getElementById('hero-consult-btn');
    btn?.addEventListener('click', () => {
        formComment.set('Здравствуйте! Хочу получить бесплатную консультацию по строительству дома.');
        isModalOpen.set(true);
    });

    const slides = document.querySelectorAll('.hero-slide');
    let currentSlide = 0;
    
    if (slides.length > 1) {
        setInterval(() => {
            slides[currentSlide].classList.remove('opacity-100', 'z-10', 'pointer-events-auto');
            slides[currentSlide].classList.add('opacity-0', 'z-0', 'pointer-events-none');
            
            currentSlide = (currentSlide + 1) % slides.length;
            
            slides[currentSlide].classList.remove('opacity-0', 'z-0', 'pointer-events-none');
            slides[currentSlide].classList.add('opacity-100', 'z-10', 'pointer-events-auto');
        }, 5000); 
    }
</script>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 1s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>