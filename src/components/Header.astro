---
// src/components/Header.astro
import Logo from './ui/Logo.astro';

const links = [
  { name: 'Проекты', href: '/projects' },
  { name: 'Портфолио', href: '/portfolio' }, 
  { name: 'Блог', href: '/blog' },
  { name: 'Контакты', href: '/contact' }, 
  { name: 'О компании', href: '/about' },
];
---
<header class="fixed top-0 left-0 w-full z-50 bg-white/90 backdrop-blur-md border-b border-gray-100/50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-24">
      
      <!-- 1. Логотип -->
      <div class="flex-shrink-0 z-50 relative">
        <Logo variant="light" />
      </div>

      <!-- 2. ДЕСКТОП МЕНЮ (МЕГА-МЕНЮ) -->
      <nav class="hidden md:flex space-x-8 items-center h-full">
        
        <!-- ПРОЕКТЫ -->
        <a href="/projects" class="font-sans text-xs lg:text-sm font-semibold uppercase tracking-wider text-marmol-navy hover:text-marmol-gold transition-colors duration-300">
          Проекты
        </a>

        <!-- ПОРТФОЛИО -->
        <a href="/portfolio" class="font-sans text-xs lg:text-sm font-semibold uppercase tracking-wider text-marmol-navy hover:text-marmol-gold transition-colors duration-300">
          Портфолио
        </a>

        <a href="/real-estate" class="font-sans text-xs lg:text-sm font-bold uppercase tracking-wider text-marmol-gold hover:text-marmol-navy transition-colors duration-300">
          Готовые дома
        </a>

        <!-- === ВЫПАДАЮЩЕЕ МЕНЮ: УСЛУГИ === -->
        <div class="group h-full flex items-center">
            <button class="font-sans text-xs lg:text-sm font-semibold uppercase tracking-wider text-marmol-navy group-hover:text-marmol-gold transition-colors duration-300 flex items-center cursor-default h-full">
                Услуги
                <!-- Стрелочка вниз -->
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3 ml-1 group-hover:rotate-180 transition-transform duration-300">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
            </button>

            <!-- Сама выпадающая панель -->
            <div class="absolute left-0 top-[calc(100%-1px)] w-full bg-white border-t border-gray-100 shadow-xl opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-300 ease-out pointer-events-none group-hover:pointer-events-auto">
                <div class="max-w-7xl mx-auto px-8 py-10 grid grid-cols-12 gap-8">
                    <!-- Колонка 1: СТРОИТЕЛЬСТВО -->
                      <div class="col-span-3 border-r border-gray-100">
                        <h3 class="text-marmol-gold font-bold uppercase tracking-widest text-xs mb-4">Строительство</h3>
                        <ul class="space-y-3">
                            <!-- Ссылка на Каркасные (эту страницу сделаем следующей) -->
                            <li>
                                <a href="/services/frame-houses" class="block text-marmol-navy hover:text-marmol-gold transition-colors text-sm">
                                    Каркасные дома
                                </a>
                            </li>
                            <li>
                                <a href="/services/gas-silicate-houses" class="block text-marmol-navy hover:text-marmol-gold transition-colors text-sm">
                                    Блочные дома
                                </a>
                            </li>
                            <li>
                                <a href="/services/business" class="block text-marmol-navy hover:text-marmol-gold transition-colors text-sm">
                                    Для бизнеса
                                </a>
                            </li>
                            <li>
                                <a href="/services/facades" class="block text-marmol-navy hover:text-marmol-gold transition-colors text-sm">
                                    Премиум фасады
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Колонка 2: ЭКОСИСТЕМА (Сервис) -->
                    <div class="col-span-3 border-r border-gray-100">
                        <h3 class="text-marmol-gold font-bold uppercase tracking-widest text-xs mb-4">Подготовка</h3>
                        <ul class="space-y-3">
                            <li><a href="/services/design" class="block text-marmol-navy hover:text-marmol-gold transition-colors text-sm">Индивидуальное проектирование</a></li>
                        </ul>
                    </div>

                    <!-- Колонка 3: АКЦЕНТ / КАРТИНКА -->
                    <div class="col-span-6 pl-8 flex flex-col justify-center bg-marmol-bg/50 rounded-r-xl p-6">
                        <h4 class="font-sans font-bold text-marmol-navy text-lg mb-2">Не знаете с чего начать?</h4>
                        <p class="text-gray-500 text-sm mb-4">Мы поможем сформулировать тех. задание и подберем лучшие решения под ваш бюджет.</p>
                        <button 
                            id="menu-meeting-btn"
                            class="text-marmol-gold font-bold uppercase tracking-wider text-xs border-b border-marmol-gold/30 hover:border-marmol-gold pb-1 w-fit transition-colors text-left cursor-pointer"
                        >
                            Записаться на встречу →
                        </button>
                    </div>

                </div>
            </div>
        </div>

        <a href="/blog" class="font-sans text-xs lg:text-sm font-semibold uppercase tracking-wider text-marmol-navy hover:text-marmol-gold transition-colors duration-300">
          Блог
        </a>

        <!-- КОМПАНИЯ (Тоже можно сделать выпадающим, но пока просто ссылка для примера) -->
        <a href="/about" class="font-sans text-xs lg:text-sm font-semibold uppercase tracking-wider text-marmol-navy hover:text-marmol-gold transition-colors duration-300">
          О компании
        </a>

      </nav>

      <!-- 3. Контакты и кнопка -->
     <div class="hidden md:flex items-center space-x-6">
        
        <div class="flex flex-col items-end">
            <a href="tel:+375291845481" class="font-body font-bold text-marmol-navy hover:text-marmol-gold transition-colors text-sm whitespace-nowrap leading-none">
              +375 (29) 184-54-81
            </a>
            <a href="/contact" class="text-[10px] text-gray-400 font-medium mt-1 hover:text-marmol-gold transition-colors">
                г. Гродно, ул. Лелевеля, 12A
            </a>
        </div>
        
    </div>

      <!-- 4. Мобильная кнопка (Гамбургер) -->
      <button id="mobile-menu-btn" class="md:hidden text-marmol-navy p-2 focus:outline-none cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- 5. Мобильное меню -->
  <div id="mobile-menu" class="hidden md:hidden fixed top-24 left-0 w-full h-[calc(100dvh-6rem)] bg-white border-b border-gray-100 shadow-xl overflow-y-auto pb-10">
    <div class="flex flex-col p-6 space-y-5">
        
        <!-- Основные разделы -->
        <a href="/projects" class="text-xl font-sans font-bold text-marmol-navy border-b border-gray-50 pb-2">
            Проекты
        </a>
        <a href="/portfolio" class="text-xl font-sans font-bold text-marmol-navy border-b border-gray-50 pb-2">
            Портфолио
        </a>
        <a href="/real-estate" class="text-xl font-sans font-bold text-marmol-gold border-b border-gray-50 pb-2">
            Готовые дома
        </a>
        
        <!-- Блок УСЛУГИ -->
        <div>
    <div class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-3">Строительство</div>
      <div class="flex flex-col space-y-3 pl-4 border-l-2 border-gray-100">

          <!-- Каркас -->
          <a href="/services/frame-houses" class="text-base text-gray-700 font-medium">
              Каркасные дома
          </a>

          <!-- Блоки (НОВОЕ) -->
          <a href="/services/gas-silicate-houses" class="text-base text-gray-700 font-medium">
              Блочные дома
          </a>
          <a href="/services/business" class="block text-marmol-navy hover:text-marmol-gold transition-colors text-sm">Для бизнеса</a>
          <a href="/services/facades" class="text-base text-gray-700 font-medium">Премиум фасады</a>
      </div>
  </div>

        <div>
            <div class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-3">Подготовка</div>
            <div class="flex flex-col space-y-3 pl-4 border-l-2 border-gray-100">
                <a href="/services/design" class="text-base text-gray-700 font-medium">Проектирование</a>
            </div>
        </div>
        
        <!-- Разделитель -->
        <div class="h-[1px] bg-gray-100 w-full my-2"></div>
        
        <!-- Доп. ссылки -->
        <a href="/about" class="text-lg font-sans font-medium text-marmol-navy">О компании</a>
        <a href="/blog" class="text-lg font-sans font-medium text-marmol-navy">Блог</a>
        <a href="/contact" class="text-lg font-sans font-medium text-marmol-navy">Контакты</a>

        <div class="pt-4">
             <a href="tel:+375291845481" class="text-2xl font-bold text-marmol-navy block mb-1">+375 (29) 184-54-81</a>
             <a href="/contact" class="text-sm text-gray-500 block mb-2">г. Гродно, ул. Лелевеля, 12A, к 6</a> <!-- ДОБАВИЛИ -->
             <p class="text-xs text-gray-400">Ежедневно с 9:00 до 18:00</p>
        </div>
    </div>
  </div>
</header>

<script>
    import { isModalOpen, formComment } from '../store/modalStore';

    function initHeader() {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');

        // Очищаем старые слушатели
        const newBtn = btn?.cloneNode(true);
        if (btn && btn.parentNode && newBtn) {
            btn.parentNode.replaceChild(newBtn, btn);
            newBtn.addEventListener('click', () => {
                // 1. Показываем/скрываем меню
                menu?.classList.toggle('hidden');
                // 2. Блокируем/разблокируем скролл страницы под меню
                document.body.classList.toggle('overflow-hidden');
            });
        }

        // Закрываем мобильное меню при клике на любую ссылку внутри него
        const mobileLinks = menu?.querySelectorAll('a');
        mobileLinks?.forEach(link => {
            link.addEventListener('click', () => {
                menu?.classList.add('hidden');
                // ОБЯЗАТЕЛЬНО возвращаем скролл странице при переходе по ссылке!
                document.body.classList.remove('overflow-hidden');
            });
        });

        // Делегирование для кнопок модалки
        document.removeEventListener('click', handleModalClicks);
        document.addEventListener('click', handleModalClicks);
    }

    function handleModalClicks(e: Event) {
        // @ts-ignore
        const target = e.target.closest('#menu-meeting-btn');
        
        if (target) {
            formComment.set('Здравствуйте! Хочу записаться на встречу в офисе для консультации.');
            isModalOpen.set(true);
            
            // Если модалка вызвана с мобильного устройства, закрываем меню и возвращаем скролл
            const menu = document.getElementById('mobile-menu');
            if (menu && !menu.classList.contains('hidden')) {
                menu.classList.add('hidden');
                document.body.classList.remove('overflow-hidden');
            }
        }
    }

    document.addEventListener('astro:page-load', initHeader);
    initHeader();
</script>